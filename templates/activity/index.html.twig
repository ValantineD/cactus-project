{% extends 'base.html.twig' %}


{% block title %}Activities{% endblock %}


{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-12 col-lg-4 order-2 order-lg-1 border-cactus">
                <h2>Catégories</h2>
            </div>


            <div class="col-12 col-lg-8 px-5 order-1 order-lg-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h1>Activities</h1>
                    <a href="{{ path('app_activity_new') }}" class="btn btn-cactus-primary">+ New Activity</a>
                </div>

                <div class="mt-3">
                    {% for activity in activities %}
                        <div class="cactus-border-shadow p-3 mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h3 class="mb-1">{{ activity.title }}</h3>
                            </div>
                            {% if activity.images %}
                                <img src="{{ asset(activity.images) }}" alt="pic_product" style="max-width: 150px" loading="lazy">
                            {% else %}
                                pas d'images
                            {% endif %}
                            <p class="mb-1 text-muted">
                                {{ activity.location }} — {{ activity.date ? activity.date|date('d/m/Y') : '-' }}</p>
                            <p class="mb-2">
                                {{ activity.description|slice(0, 100) }}
                                {% if activity.description|length > 100 %}…voir plus{% endif %}</p>
                            <p> créée par : {{ activity.user ? activity.user.username : 'Unknown' }}</p>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_activity_show', {id: activity.id}) }}"
                                   class="btn btn-sm btn-cactus-secondary">View</a>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-muted">No activities yet.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

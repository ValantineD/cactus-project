{% extends 'base.html.twig' %}
{% block title %}Recherche Activité{% endblock %}

{% block body %}
    <div class="container-fluid px-4 py-3">

        <div class="row g-3">
            <div class="col-12 col-lg-6 order-lg-1 order-2">
                <div class="row g-3">
                    {% for activity in activities %}
                        <div class="col-12 col-sm-6">
                            <a href="{{ path('app_activity_show', {id: activity.id}) }}"
                               class="text-decoration-none text-dark">
                                <div class="h-100" style="border-radius: 8px; overflow: hidden;">
                                    <div style="height: 200px; overflow: hidden; background: #e9e9e9;">
                                        {% if activity.imageFiles is not empty %}
                                            <img src="{{ asset(activity.imageFiles[0].filename) }}" alt="{{ activity.title }}"
                                                 style="max-width: 500px; object-fit: cover;"
                                                 loading="lazy" class="w-100 h-100">
                                        {% else %}
                                            <div
                                                class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary bg-opacity-25">
                                                <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between gap-1 p-1">
                                    {% for theme in activity.themes %}
                                        <div class="d-flex badges-theme align-items-center justify-content-center gap-1 p-1 {{ (activity.themes|length  > 1) ? "w-50" : "w-100" }}">
                                            <img src="{{ asset(theme.iconFilename) }}" alt="{{ theme.title }}" loading="lazy"
                                                 style="height: 15px">
                                            <span style="font-size: 15px"><strong>{{ theme.title }}</strong></span>
                                        </div>
                                    {% endfor %}
                                    </div>

                                    <div class="px-3 pt-1 pb-2">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="mb-0" style="font-size: 1rem;">{{ activity.title }}</h5>
                                            <span class="text-muted ms-2 flex-shrink-0"
                                                  style="font-size: 0.85rem; white-space: nowrap;">
                                      </span>
                                        </div>

                                        <div class="d-flex justify-content-between mt-1">
                                            <small class="text-muted">{{ activity.location }}</small>
                                            <small
                                                class="text-muted">{{ activity.date ? activity.date|date('M d') : '' }}</small>
                                        </div>

                                        {% if activity.tags %}
                                            <div class="d-flex flex-wrap gap-1 mt-2">
                                                {% for tag in activity.tags %}
                                                    <span class="badge px-2 cactus-tags">{{ tag }}</span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>

                                </div>
                            </a>
                        </div>
                    {% else %}
                        <div class="col-12">
                            <p class="text-muted">Aucune activité trouvée.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="col-12 col-lg-6 order-lg-2 order-1 container-map">
                <div class="cactus-border-shadow d-flex align-items-center justify-content-center"
                     style="height: 500px; width: 600px; border-radius: 8px; background: #e0e0e0; position: fixed">
                    <div class="text-center text-muted">
                        <i class="bi bi-map" style="font-size: 38px"></i>
                        <p class="mt-2 mb-0" style="font-size: 0.9rem;">Pas de Carte....</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}





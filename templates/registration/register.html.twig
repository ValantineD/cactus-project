{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <h1 class="logo text-center py-4">Don't be a Cacti, <br> Be a Cact-us!</h1>

    <div class="cactus-border-shadow  w-100 mx-auto p-3 p-lg-5" style="max-width: 700px">
        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.username) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword) }}
        {{ form_row(registrationForm.birthday) }}

        <div class="py-4">
            <button type="submit" class="btn btn-lg btn-cactus-primary d-block w-100">S'inscrire</button>
        </div>

        <a href="{{ path('app_login') }}"
           class="h6 text-center d-block link-offset-2 link-underline-dark link-underline-opacity-0 link-underline-opacity-75-hover">Vous
            avez déjà un compte ?</a>

        {{ form_end(registrationForm) }}
    </div>
{% endblock %}

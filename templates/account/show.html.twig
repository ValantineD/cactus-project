{% extends 'base.html.twig' %}

{% block title %}My Account{% endblock %}

{% block body %}
    <h1>My Profile</h1>

    <img src="{{ asset(user.profileFilename) }}" alt="pic_product">

    <table class="table">
        <tbody>
        <tr>
            <th>Username</th>
            <td>{{ user.username }}</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>{{ user.email }}</td>
        </tr>
        <tr>
            <th>Created At</th>
            <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}</td>
        </tr>
        <tr>
            <th>Location</th>
            <td>{{ user.location }}</td>
        </tr>
        </tbody>
    </table>

    <a href="{{ path('app_home') }}">back to home</a>
    <a href="{{ path('app_logout') }}">Logout</a>

    {% if app.user %}
        <a href="{{ path('app_user_edit', {'username': user.username}) }}">edit</a>
    {% endif %}


{% endblock %}
